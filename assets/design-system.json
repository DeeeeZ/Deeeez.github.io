{
  "meta": {
    "name": "Slate Authority Design System",
    "version": "1.0.0",
    "description": "Slate, navy, copper, and editorial typography design language for the DeyaAldeen enterprise finance automation portfolio.",
    "lastUpdated": "2026-04-24",
    "sourceReference": "slate-authority-design-system-v1.html"
  },
  "colors": {
    "brand": {
      "navy900": "#0A1E42",
      "copper": "#D4A574",
      "copperLight": "#E8C9A8",
      "copperDark": "#B8864E",
      "blue600": "#2563EB",
      "blue500": "#3B82F6",
      "blue400": "#60A5FA"
    },
    "slate": {
      "900": "#0F172A",
      "800": "#1E293B",
      "700": "#334155",
      "600": "#475569",
      "500": "#64748B",
      "400": "#94A3B8",
      "200": "#E2E8F0",
      "100": "#F1F5F9",
      "50": "#F8FAFC"
    },
    "light": {
      "background": {
        "main": "#FFFFFF",
        "card": "#FFFFFF",
        "darkSection": "#0A1E42"
      },
      "text": {
        "primary": "#1E293B",
        "secondary": "#475569",
        "tertiary": "#64748B"
      },
      "accent": {
        "primary": "#D4A574",
        "primaryRGB": "212, 165, 116",
        "hover": "#B8864E",
        "light": "#E8C9A8"
      },
      "border": {
        "subtle": "rgba(15, 23, 42, 0.12)",
        "divider": "rgba(15, 23, 42, 0.06)"
      },
      "overlay": {
        "light": "rgba(255, 255, 255, 0.95)",
        "spotlight": "rgba(212, 165, 116, 0.18)"
      }
    },
    "dark": {
      "background": {
        "main": "#0A1E42",
        "card": "#102A56",
        "darkSection": "#061633"
      },
      "text": {
        "primary": "#F1F5F9",
        "secondary": "#E2E8F0",
        "tertiary": "#94A3B8"
      },
      "accent": {
        "primary": "#E8C9A8",
        "primaryRGB": "232, 201, 168",
        "hover": "#D4A574",
        "light": "#F3DEC8"
      },
      "border": {
        "subtle": "rgba(255, 255, 255, 0.1)",
        "divider": "rgba(255, 255, 255, 0.05)"
      },
      "overlay": {
        "dark": "rgba(10, 30, 66, 0.95)",
        "spotlight": "rgba(232, 201, 168, 0.18)"
      }
    },
    "semantic": {
      "success": "#22C55E",
      "error": "#EF4444",
      "warning": "#F59E0B",
      "info": "#2563EB"
    }
  },
  "typography": {
    "fontFamilies": {
      "serif": {
        "name": "Merriweather",
        "fallback": "Georgia, serif",
        "googleFonts": "Merriweather:wght@700;900",
        "usage": "Headlines, display text, brand names, large numbers"
      },
      "sans": {
        "name": "IBM Plex Sans",
        "fallback": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "googleFonts": "IBM+Plex+Sans:wght@300;400;500;600;700",
        "usage": "Body text, paragraphs, general UI"
      },
      "mono": {
        "name": "IBM Plex Mono",
        "fallback": "monospace",
        "googleFonts": "IBM+Plex+Mono:wght@400;500;600;700",
        "usage": "Labels, navigation, buttons, technical text, badges"
      }
    },
    "textStyles": {
      "heroHeadline": {
        "fontFamily": "serif",
        "fontSize": "clamp(42px, 5vw, 64px)",
        "fontWeight": 900,
        "lineHeight": 1.1,
        "letterSpacing": "-0.01em"
      },
      "sectionHeadline": {
        "fontFamily": "serif",
        "fontSize": "clamp(28px, 3.5vw, 40px)",
        "fontWeight": 700,
        "lineHeight": 1.2,
        "letterSpacing": "-0.01em"
      },
      "bodyRegular": {
        "fontFamily": "sans",
        "fontSize": "16px",
        "fontWeight": 400,
        "lineHeight": 1.7
      },
      "label": {
        "fontFamily": "mono",
        "fontSize": "11px",
        "fontWeight": 600,
        "lineHeight": 1.5,
        "letterSpacing": "0.25em",
        "textTransform": "uppercase"
      },
      "buttonText": {
        "fontFamily": "mono",
        "fontSize": "14px",
        "fontWeight": 600,
        "lineHeight": 1.5,
        "letterSpacing": "0.1em",
        "textTransform": "uppercase"
      }
    }
  },
  "spacing": {
    "scale": {
      "xs": "4px",
      "sm": "8px",
      "md": "16px",
      "lg": "24px",
      "xl": "32px",
      "2xl": "48px",
      "3xl": "64px",
      "4xl": "96px"
    },
    "semantic": {
      "containerPaddingMobile": "24px",
      "containerPaddingDesktop": "48px",
      "sectionPaddingY": "96px",
      "cardPadding": "32px",
      "cardPaddingLarge": "48px",
      "buttonPaddingX": "32px",
      "buttonPaddingY": "16px",
      "navGap": "32px"
    }
  },
  "borders": {
    "radius": {
      "sm": "4px",
      "md": "8px",
      "lg": "12px",
      "full": "9999px"
    },
    "styles": {
      "subtle": "1px solid var(--border-subtle)",
      "accent": "1px solid var(--accent)",
      "accentLeft": "3px solid var(--accent)"
    }
  },
  "shadows": {
    "copper": "0 6px 20px rgba(212, 165, 116, 0.35)",
    "card": "0 4px 16px rgba(212, 165, 116, 0.08)",
    "copperGlow": "0 0 0 3px rgba(212, 165, 116, 0.12)"
  },
  "components": {
    "navigation": {
      "background": {
        "scrolledLight": "rgba(255, 255, 255, 0.95)",
        "scrolledDark": "rgba(10, 30, 66, 0.95)"
      },
      "backdropFilter": "blur(12px)",
      "borderBottom": "1px solid var(--border-subtle)"
    },
    "buttons": {
      "primary": {
        "background": "var(--section-dark-bg)",
        "color": "#FFFFFF",
        "hoverBackground": "var(--accent)",
        "hoverColor": "#FFFFFF"
      },
      "secondary": {
        "background": "transparent",
        "color": "var(--text-primary)",
        "border": "1px solid var(--border-subtle)",
        "hoverBorderColor": "var(--accent)"
      }
    },
    "cards": {
      "background": "var(--bg-card)",
      "border": "1px solid var(--border-subtle)",
      "radius": "8px",
      "spotlightGradient": "radial-gradient(600px circle at var(--mouse-x) var(--mouse-y), rgba(212, 165, 116, 0.18), transparent 40%)"
    },
    "forms": {
      "input": {
        "background": "transparent",
        "borderBottom": "1px solid var(--border-subtle)",
        "focusBorderColor": "var(--accent)"
      },
      "label": {
        "fontFamily": "mono",
        "color": "var(--text-tertiary)",
        "focusColor": "var(--accent)"
      }
    }
  },
  "cssVariables": {
    "light": {
      "--bg-main": "#FFFFFF",
      "--bg-card": "#FFFFFF",
      "--text-primary": "#1E293B",
      "--text-secondary": "#475569",
      "--text-tertiary": "#64748B",
      "--accent": "#D4A574",
      "--accent-dark": "#B8864E",
      "--accent-light": "#E8C9A8",
      "--accent-rgb": "212, 165, 116",
      "--link-blue": "#2563EB",
      "--border-subtle": "rgba(15, 23, 42, 0.12)",
      "--section-dark-bg": "#0A1E42",
      "--tech-grid-color": "rgba(15, 23, 42, 0.06)"
    },
    "dark": {
      "--bg-main": "#0A1E42",
      "--bg-card": "#102A56",
      "--text-primary": "#F1F5F9",
      "--text-secondary": "#E2E8F0",
      "--text-tertiary": "#94A3B8",
      "--accent": "#E8C9A8",
      "--accent-dark": "#D4A574",
      "--accent-light": "#F3DEC8",
      "--accent-rgb": "232, 201, 168",
      "--link-blue": "#60A5FA",
      "--border-subtle": "rgba(255, 255, 255, 0.1)",
      "--section-dark-bg": "#061633",
      "--tech-grid-color": "rgba(255, 255, 255, 0.05)"
    }
  }
}
